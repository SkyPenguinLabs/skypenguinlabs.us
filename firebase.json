{
  "hosting": {
    "public": "public",
    "cleanUrls": true,
    "trailingSlash": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/shop",
        "destination": "https://shop.skypenguinlabs.com",
        "type": 301
      },
      {
        "source": "/shop/**",
        "destination": "https://shop.skypenguinlabs.com",
        "type": 301
      }
    ]
  }
}
